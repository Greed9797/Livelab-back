# Banco de dados (PostgreSQL via Supabase ou outro provider)
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Supabase (apenas se usar Storage para upload de arquivos)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# Autenticação JWT
JWT_SECRET=minimo-32-caracteres-troque-por-segredo-forte
JWT_EXPIRES_IN=15m

# Servidor
PORT=3001
NODE_ENV=development

# Asaas REMOVIDO — substituído 100% por Appmax. Vars abaixo só pra
# documentar que não devem mais ser usadas.
# ASAAS_API_KEY (deprecated)
# ASAAS_WEBHOOK_TOKEN (deprecated)
# ASAAS_SANDBOX (deprecated)

# TikTok OAuth — obrigatório para integração com TikTok Live
TIKTOK_OAUTH_ENABLED=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.seudominio.com/v1/tiktok/callback
TIKTOK_WEBHOOK_REQUIRE_SIGNATURE=true
TIKTOK_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# TikTok Live Connector — circuit breaker
TIKTOK_CB_THRESHOLD=5
TIKTOK_CB_WINDOW_MS=300000
TIKTOK_MAX_CONNECTORS=20

# CORS — origens permitidas (separadas por vírgula). Vazio = permitir tudo (dev only)
CORS_ORIGIN=https://app.seudominio.com

# Frontend — base URL pra montar links em e-mails (reset/convite) e redirect OAuth.
# Default em runtime: https://livelab-3601f.web.app (caso ausente).
FRONTEND_URL=https://app.grupolivelab.com.br

# SSL do banco — manter true em produção
DB_SSL_REJECT_UNAUTHORIZED=true

# S-07: criptografia AES-256-GCM dos tokens TikTok no banco.
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# S-13: secret dedicado para HMAC do state OAuth (separado do JWT_SECRET).
# Mesma sugestão de geração acima.
OAUTH_STATE_SECRET=

# S-11: opcional. Se setado, /health exige header X-Health-Token pra responder.
HEALTH_CHECK_TOKEN=

# S-08: secret obrigatório em produção. Webhook bio-crm rejeita se faltar.
BIO_CRM_WEBHOOK_SECRET=
BIO_WEBHOOK_DEFAULT_FRANQUEADORA_ID=

# Appmax (gateway de pagamento alternativo ao Asaas).
# APP_ID vem do painel Appmax → Desenvolvimento → ID do aplicativo.
# API_KEY é gerada no painel após instalação concluída.
APPMAX_APP_ID=
APPMAX_API_KEY=
APPMAX_WEBHOOK_SECRET=
APPMAX_BASE_URL=https://admin.appmax.com.br/api/v3

# ─────────────────────────────────────────────
# Observability — Sentry
# Opcional: se ausente, Sentry desativado. Em prod recomendado.
SENTRY_DSN=
SENTRY_RELEASE=liveshop_saas_api@1.0.0

# ─────────────────────────────────────────────
# F1: Notificações por e-mail (Resend)
# Se RESEND_API_KEY ausente, hooks viram no-op (degradação segura).
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@grupolivelab.com.br

# ─────────────────────────────────────────────
# Backup S3 (opcional — sem BACKUP_S3_BUCKET o cron é ignorado automaticamente)
# Compatível com AWS S3 e Cloudflare R2.
BACKUP_S3_BUCKET=liveshop-prod-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=AKIA...
BACKUP_S3_SECRET_KEY=
# Para Cloudflare R2: BACKUP_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT=
# Retenção em dias (default: 30)
BACKUP_RETENTION_DAYS=30
