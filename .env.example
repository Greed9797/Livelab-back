# Banco de dados (PostgreSQL via Supabase ou outro provider)
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Supabase (apenas se usar Storage para upload de arquivos)
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key-aqui

# Autenticação JWT
JWT_SECRET=minimo-32-caracteres-troque-por-segredo-forte
JWT_EXPIRES_IN=15m

# Servidor
PORT=3001
NODE_ENV=development

# Asaas (gateway de pagamento) — deixe vazio para desabilitar faturamento automático
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_SANDBOX=true

# TikTok OAuth — obrigatório para integração com TikTok Live
TIKTOK_OAUTH_ENABLED=false
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.seudominio.com/v1/tiktok/callback
TIKTOK_WEBHOOK_REQUIRE_SIGNATURE=false
TIKTOK_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# TikTok Live Connector — circuit breaker
TIKTOK_CB_THRESHOLD=5
TIKTOK_CB_WINDOW_MS=300000
TIKTOK_MAX_CONNECTORS=20

# CORS — origens permitidas (separadas por vírgula). Vazio = permitir tudo (dev only)
CORS_ORIGIN=https://app.seudominio.com

# Frontend (redirect OAuth)
FRONTEND_URL=https://app.seudominio.com

# SSL do banco — manter true em produção
DB_SSL_REJECT_UNAUTHORIZED=true
